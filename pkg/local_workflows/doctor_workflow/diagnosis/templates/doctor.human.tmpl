{{- define "finding" -}}
  {{ if .Subject }}{{ .Subject }} {{ end }}[{{ .Kind }}] {{ trimRight .Message }}{{ if .Code }} ({{ .Code }}){{ end }}
{{- range .Remediation }}
      → {{ . }}
{{- end -}}
{{- range .Details }}
      {{ . }}
{{- end }}
{{- "\n" }}
{{- end -}}

{{- define "main" -}}
{{- printf "%s" (title "Snyk Doctor Diagnostic Report") -}}
{{- printf "%s" (title "Basic Information") -}}
{{- if .Summary.Fields -}}
{{- range .Summary.Fields -}}
  - {{ .Key }}: {{ .Value }}{{- "\n" }}
{{- end -}}
{{- end }}

{{- printf "%s" (title "Symptions") -}}
{{- range .Findings -}}
 - {{- template "finding" . }}
{{- end }}
{{- end -}}

{{- template "main" . -}}
